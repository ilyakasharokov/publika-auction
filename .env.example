# Telegram Bot
PUBLIKA_AUCTION_BOT_TOKEN=your_bot_token_here

# Telegram API endpoint.
# For cloud API (default, 30 msg/s limit):
PUBLIKA_AUCTION_BOT_TG_ENDPOINT=https://api.telegram.org/bot%s/%s
# For Local Bot API Server (1000 msg/s, see docs/local-bot-api.md):
# PUBLIKA_AUCTION_BOT_TG_ENDPOINT=http://localhost:8081/bot%s/%s

# Local Bot API Server credentials (only needed when using telegram-bot-api service)
# Get these at https://my.telegram.org → API development tools
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# HTTP server
PUBLIKA_AUCTION_BOT_ADDR=:8002

# MongoDB
PUBLIKA_AUCTION_BOT_MONGO_URI=mongodb://localhost:27017
PUBLIKA_AUCTION_BOT_MONGO_DB=auction

# Redis (for distributed bid locking)
PUBLIKA_AUCTION_BOT_REDIS_ADDR=localhost:6379
PUBLIKA_AUCTION_BOT_REDIS_PWD=
PUBLIKA_AUCTION_BOT_REDIS_DB=0

# Admin panel
PUBLIKA_AUCTION_BOT_ADMIN_USER=admin
PUBLIKA_AUCTION_BOT_ADMIN_PASSWORD=changeme
PUBLIKA_AUCTION_BOT_SESSION_SECRET=change-this-to-a-random-secret

# Auction defaults
PUBLIKA_AUCTION_BOT_BID_STEP=2000
